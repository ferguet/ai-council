# Copia este archivo a backend/.env y rellena las claves que tengas.
# El sistema detecta automaticamente que proveedores estan configurados.
# El proveedor "mock" siempre funciona, sin necesidad de ninguna clave.

# Google AI Studio (https://aistudio.google.com) - nivel gratuito
GEMINI_API_KEY=

# Groq (https://console.groq.com) - nivel gratuito, respuestas muy rapidas
GROQ_API_KEY=

# DeepSeek (https://platform.deepseek.com) - de pago (muy barato), pide
# metodo de pago aunque sea para gastar centimos
DEEPSEEK_API_KEY=

# GLM / Zhipu AI (https://open.bigmodel.cn o https://z.ai) - nivel gratuito
# con limite diario, pide verificacion por telefono al crear la cuenta
GLM_API_KEY=

# Ollama local (https://ollama.com) - gratis e ilimitado, corre en tu maquina
OLLAMA_BASE_URL=http://localhost:11434

# Reservados para cuando quieras anadirlos (de pago tras el credito inicial)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Que proveedor/modelo usa el Director para coordinar el debate
DIRECTOR_PROVIDER=mock
DIRECTOR_MODEL=director-v1

# Limite de seguridad de turnos por debate (evita bucles infinitos)
MAX_DEBATE_TURNS=20

# --- Ciudad Virtual (Persistent AI Civilization) ---

# Cuanto tiempo real dura 1 tick del motor de simulacion (segundos)
SIM_TICK_SECONDS=60
# Cuantas horas simuladas avanza cada tick
SIM_HOURS_PER_TICK=1
# Minimo tiempo real entre llamadas reales de "pensamiento" por ciudadano
SIM_REAL_AI_INTERVAL_MINUTES=15
# Arrancar el motor de simulacion solo al iniciar el servidor
SIM_AUTOSTART=true

# Cadena de conexion a Postgres (solo hace falta si despliegas en la nube
# con un disco no persistente, p.ej. Render free + Supabase gratis).
# En local, si se deja vacio, la ciudad se guarda en backend/data/city_state.json
DATABASE_URL=
